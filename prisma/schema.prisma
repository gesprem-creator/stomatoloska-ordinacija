// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Appointment {
  id              String   @id @default(cuid())
  fullName        String   // Ime i prezime
  phone           String
  date            DateTime
  time            String   // Format: "HH:MM"
  duration        Int      // Duration in minutes
  appointmentType String   // "popravka", "lecenje", "ortodont", "proteza"
  numberOfPeople  Int      @default(1)
  viberReminder   Boolean  @default(false) // Da li korisnik želi Viber podsetnik
  reminderSent    Boolean  @default(false) // Da li je podsetnik već poslat
  cancelled       Boolean  @default(false) // Da li je termin otkazan
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Patient {
  id               String   @id @default(cuid())
  fullName         String   // Ime i prezime
  phone            String   // Telefon (jedinstven)
  totalAppointments Int     @default(0) // Ukupan broj termina
  lastVisit        DateTime? // Datum poslednje posete
  viberReminder    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([phone]) // Jedinstven broj telefona
}

model ViberSubscriber {
  id           String   @id @default(cuid())
  viberId      String   @unique // Viber user ID
  phone        String   // Telefon za povezivanje sa terminima
  name         String?  // Ime korisnika
  subscribedAt DateTime @default(now())
  isActive     Boolean  @default(true)
}
